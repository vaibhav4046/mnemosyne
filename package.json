{
  "name": "own-wiki",
  "productName": "Own Wiki",
  "version": "1.0.0",
  "description": "Local-first self-improving AI memory wiki — your own Wikipedia powered by Ollama.",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "build:exe": "next build && electron-builder --win portable --publish never"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.60.0",
    "chokidar": "^5.0.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.16.0",
    "mammoth": "^1.12.0",
    "nanoid": "^5.1.11",
    "next": "16.2.6",
    "ollama": "^0.6.3",
    "p-queue": "^9.3.0",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.60.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-force-graph-3d": "^1.29.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "three": "^0.184.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.ownwiki.app",
    "productName": "Own Wiki",
    "asar": true,
    "compression": "normal",
    "files": [
      "electron/**/*",
      "public/**/*",
      ".next/standalone/**/*",
      ".next/static/**/*",
      "vault/**/*",
      "data/**/*"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "app/.next/standalone",
        "filter": ["**/*"]
      },
      {
        "from": ".next/static",
        "to": "app/.next/standalone/.next/static",
        "filter": ["**/*"]
      },
      {
        "from": "public",
        "to": "app/.next/standalone/public",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "portable": {
      "artifactName": "OwnWiki-${version}-portable.exe"
    },
    "directories": {
      "output": "dist-electron"
    }
  }
}
